# Exemplo de variáveis de ambiente (NÃO coloque segredos aqui)
# Copie para .env.local e preencha com seus valores.

# --- Next.js / Supabase (App) ---
# URL pública do app (links de e-mail: reset de senha, etc.)
# Produção: https://nossocrm-delta-ten.vercel.app
# Use APP_URL no servidor e NEXT_PUBLIC_APP_URL no client.
APP_URL=
NEXT_PUBLIC_APP_URL=

# URL do projeto no Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública (anon) do Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de service role (APENAS server-side). Necessária para alguns scripts e rotas internas dev-only.
# Nunca exponha no client e nunca comite.
SUPABASE_SERVICE_ROLE_KEY=

# Personal Access Token da conta Supabase (Settings → Account → Access Tokens).
# Opcional: permite auto-aplicar migrações pontuais (ex.: colunas OpenRouter) via Management API.
SUPABASE_ACCESS_TOKEN=

# --- Dev-only ---
# Habilita rotas internas de teste de IA em desenvolvimento.
ALLOW_AI_TEST_ROUTE=false

# Habilita rotas internas de mock de UI em desenvolvimento.
ALLOW_UI_MOCKS_ROUTE=false

# --- Installer (ops only) ---
# Se INSTALLER_ENABLED nao estiver definido, o instalador fica liberado ate a primeira instalacao.
# Defina como false para desativar o instalador (recomendado apos o setup).
INSTALLER_ENABLED=false

# Token opcional para proteger o instalador (se definido, passa a ser obrigatorio).
INSTALLER_TOKEN=

# --- Licença / cobrança ---
# Quantidade de dias de teste para uma nova instalação de cliente.
LICENSE_DEFAULT_TRIAL_DAYS=14

# Token secreto para webhooks internos de licença/cobrança.
# Envie no header x-license-webhook-token.
LICENSE_WEBHOOK_TOKEN=
